#!/bin/bash

# Create CSV file with header
> tests.csv

Generate combinations of tissue option, number of springs
for file in "rect00125.vtk" "rect005.vtk" "rect0025.vtk" "rect001.vtk" "rectlow2.vtk"; do
    for ym in "1e7" "5e7" "2e7" "1e8"; do
        echo "$file,$ym" >> tests.csv
    done
done

echo "CSV file 'tests.csv' created successfully!"
cat tests.csv